# Copia este archivo a .env o reusa el .env del curso lca-lc-foundations.
# El script carga primero ../lca-lc-foundations/.env y luego este si existe.

OPENAI_API_KEY=tu_openai_api_key
TAVILY_API_KEY=tu_tavily_api_key

# LangSmith para trazabilidad
LANGSMITH_API_KEY=tu_langsmith_api_key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agente-noticias-win

# Destinatario y modelo (opcional, ya tienen default en config.py)
NEWS_RECIPIENT=jquispeh@win.pe
NEWS_MODEL=gpt-5-nano
