# Copia este archivo a .env y completa tus claves.
# Este proyecto usa su PROPIO .env (ya no depende del .env del curso).

OPENAI_API_KEY=tu_openai_api_key
TAVILY_API_KEY=tu_tavily_api_key

# LangSmith para trazabilidad
LANGSMITH_API_KEY=tu_langsmith_api_key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agente-noticias-win

# Destinatarios (separados por coma para enviar a varios directivos) y modelo
NEWS_RECIPIENT=directivo1@win.pe,directivo2@win.pe
NEWS_MODEL=gpt-5-mini

# Supabase (historial anti-repeticion). Proyecto: Automatizaciones.
SUPABASE_URL=https://nknpunmqivtvbiwaubqd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key

# Cuantas semanas hacia atras se revisan para no repetir noticias (opcional)
DEDUP_WEEKS=6
