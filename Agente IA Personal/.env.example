# Copia este archivo a .env y completa tus claves.
# El paquete carga primero ../lca-lc-foundations/.env (si existe) y luego este .env local.

OPENAI_API_KEY=tu_openai_api_key
TAVILY_API_KEY=tu_tavily_api_key

# LangSmith para trazabilidad
LANGSMITH_API_KEY=tu_langsmith_api_key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agente-ia-personal

# Destinatario del correo (tu propio email) y modelo (tienen default en config.py)
NEWS_RECIPIENT=tu_correo@ejemplo.com
NEWS_MODEL=gpt-5-mini
